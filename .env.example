# ===========================================
# Wallet Pass Generation — Environment Config
# ===========================================

# --- Apple Wallet ---
# Get these from Apple Developer Portal > Certificates, Identifiers & Profiles
APPLE_TEAM_ID=
APPLE_PASS_TYPE_ID=pass.com.fidely.loyalty
APPLE_PASS_CERT_PATH=./certs/pass.pem
APPLE_PASS_KEY_PATH=./certs/pass-key.pem
APPLE_PASS_CERT_PASSWORD=
APPLE_WWDR_CERT_PATH=./certs/wwdr.pem

# --- Google Wallet ---
# Get these from Google Cloud Console > Wallet API
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=
GOOGLE_WALLET_PRIVATE_KEY=

# --- Higgsfield AI (Content Generation) ---
# Get these from https://cloud.higgsfield.ai/api-keys
HF_API_KEY=
HF_API_SECRET=

# --- Supabase ---
# Get these from Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe Billing ---
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email Notifications ---
# Admin email for new signup notifications
ADMIN_NOTIFICATION_EMAIL=hello@fidely.com.au
# Resend API key for sending emails (https://resend.com)
RESEND_API_KEY=
